{
  "version": "2.2.0",
  "owasp_asi": "ASI02,ASI05,ASI01",
  "categories": {
    "remote_code_execution": {
      "severity": "critical", "action": "block",
      "patterns": [
        "curl\\b[^\\n]*\\|\\s*(sh|bash|python|perl|ruby|node)",
        "wget\\b[^\\n]*\\|\\s*(sh|bash|python|perl|ruby|node)",
        "curl\\b[^\\n]*\\|",
        "wget\\b[^\\n]*\\|",
        "socat\\s+.*EXEC",
        "nc\\s+-[ce]\\s",
        "busybox\\s+(sh|ash|wget|curl)",
        "python[23]?\\s+-c\\s+['\"]?import",
        "perl\\s+-e\\s",
        "ruby\\s+-e\\s",
        "node\\s+-e\\s"
      ]
    },
    "dynamic_execution": {
      "severity": "critical", "action": "block",
      "patterns": [
        "eval\\(",
        "exec\\(",
        "Function\\(",
        "subprocess\\.call.*shell.*True",
        "subprocess\\.run.*shell.*True",
        "subprocess\\.Popen.*shell.*True",
        "os\\.system\\(",
        "os\\.popen\\(",
        "child_process\\.exec\\(",
        "child_process\\.spawn\\(",
        "compile\\(.*\\bexec\\b"
      ]
    },
    "destructive": {
      "severity": "critical", "action": "require_approval",
      "patterns": [
        "rm\\s+-rf", "rm\\s+-r\\s+/",
        "mkfs\\.", "dd\\s+if=",
        "shred\\s+", "wipe\\s+",
        "find\\s+.*-delete",
        "DROP\\s+TABLE", "DROP\\s+DATABASE",
        "DELETE\\s+FROM.*WHERE\\s+1", "TRUNCATE\\s+TABLE"
      ]
    },
    "permission_escalation": {
      "severity": "high", "action": "require_approval",
      "patterns": [
        "chmod\\s+777", "chmod\\s+-R\\s+777",
        "sudo\\s+", "su\\s+-",
        "doas\\s+", "pkexec\\s+"
      ]
    },
    "config_modification": {
      "severity": "high", "action": "require_approval",
      "patterns": [
        "\\.bashrc", "\\.profile", "\\.zshrc", "\\.bash_profile",
        "crontab", "\\.git/hooks/", "sudoers",
        "/etc/passwd", "/etc/shadow", "\\.ssh/authorized_keys",
        "systemd.*--user"
      ]
    },
    "deserialization": {
      "severity": "high", "action": "warn",
      "patterns": [
        "pickle\\.load", "pickle\\.loads",
        "yaml\\.unsafe_load", "yaml\\.load\\(",
        "unserialize\\(",
        "marshal\\.loads\\("
      ]
    },
    "data_exfiltration": {
      "severity": "critical", "action": "block",
      "patterns": [
        "curl\\s*.*-d\\s*@", "curl\\s*.*--data\\s*@",
        "curl\\s*.*-X\\s+POST.*\\.env",
        "wget\\s*.*--post-file",
        "nc\\s+-[lp].*-e",
        "socat\\s+.*TCP"
      ]
    },
    "shell_interpolation": {
      "severity": "critical", "action": "block",
      "description": "Shell string interpolation in exec calls — enables command injection (e.g. TUI execAsync(`npx add ${source}`))",
      "patterns": [
        "exec(?:Sync|Async|File)?\\s*\\(\\s*`[^`]*\\$\\{",
        "spawn\\s*\\(\\s*`[^`]*\\$\\{",
        "child_process\\.[a-zA-Z]+\\s*\\([^)\\n]*\\$\\{",
        "execFileSync\\s*\\([^,\\n]*\\$\\{",
        "spawnSync\\s*\\([^,\\n]*\\$\\{"
      ]
    },
    "autonomous_ai_cli": {
      "severity": "high", "action": "require_approval",
      "description": "AI coding CLI invoked in fully-autonomous / no-approval mode — uncontrolled code execution",
      "patterns": [
        "codex.*--full-auto",
        "aider.*--yes(?:-always)?",
        "claude.*--dangerously-skip-permissions",
        "claude.*--no-permission-prompt",
        "cursor.*--auto-approve",
        "npx.*skills.*add.*--force",
        "npx.*openclaw.*--auto",
        "continue.*--auto-accept"
      ]
    }
  }
}
